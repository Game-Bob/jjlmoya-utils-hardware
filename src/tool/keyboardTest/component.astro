---
import type { KnownLocale } from '../../types';
import type { TestTecladoUI } from './ui';
import { Icon } from 'astro-icon/components';

interface Props {
  locale?: KnownLocale;
  ui?: Record<string, unknown>;
}

const { ui } = Astro.props;
const t = (ui ?? {}) as TestTecladoUI;

const keyClass = 'tt-key';
const activeClass = 'tt-key-active';
const testedClass = 'tt-key-tested';
---

<div id="keyboard-tester-root" class="tt-wrapper" data-active-class={activeClass} data-tested-class={testedClass}>
  
  <div class="tt-container">
    <div class="tt-card">
      <div class="tt-header">
        <div class="tt-header-left">
          <div class="tt-badge">
            <Icon name="mdi:keyboard-outline" class="tt-badge-icon" />
            {t.badge}
          </div>
          <h2 class="tt-title">{t.title}</h2>
          <p class="tt-description">{t.description}</p>
        </div>

        <div class="tt-stats">
          <div class="tt-stat-box">
            <div class="tt-stat-label">{t.simultaneousLabel}</div>
            <div class="tt-stat-value" id="max-kro">0</div>
          </div>
          <button id="reset-btn" class="tt-reset-btn" title={t.resetBtn}>
            <Icon name="mdi:refresh" class="tt-reset-icon" />
          </button>
        </div>
      </div>

      <div class="tt-keyboard-wrapper">
        <div class="tt-keyboard" id="keyboard-base">
        <div class="tt-row">
          <div class={`${keyClass} tt-key-esc`} data-code="Escape">ESC</div>
          <div class="tt-spacer-8"></div>
          <div class={`${keyClass} tt-key-f`} data-code="F1">F1</div>
          <div class={`${keyClass} tt-key-f`} data-code="F2">F2</div>
          <div class={`${keyClass} tt-key-f`} data-code="F3">F3</div>
          <div class={`${keyClass} tt-key-f`} data-code="F4">F4</div>
          <div class="tt-spacer-4"></div>
          <div class={`${keyClass} tt-key-f`} data-code="F5">F5</div>
          <div class={`${keyClass} tt-key-f`} data-code="F6">F6</div>
          <div class={`${keyClass} tt-key-f`} data-code="F7">F7</div>
          <div class={`${keyClass} tt-key-f`} data-code="F8">F8</div>
          <div class="tt-spacer-4"></div>
          <div class={`${keyClass} tt-key-f`} data-code="F9">F9</div>
          <div class={`${keyClass} tt-key-f`} data-code="F10">F10</div>
          <div class={`${keyClass} tt-key-f`} data-code="F11">F11</div>
          <div class={`${keyClass} tt-key-f`} data-code="F12">F12</div>
          <div class="tt-spacer-4"></div>
          <div class={`${keyClass} tt-key-sm`} data-code="PrintScreen">PRT</div>
          <div class={`${keyClass} tt-key-sm`} data-code="ScrollLock">SCR</div>
          <div class={`${keyClass} tt-key-sm`} data-code="Pause">PAU</div>
        </div>

        <div class="tt-row">
          <div class={`${keyClass} tt-key-sm`} data-code="Backquote">`</div>
          <div class={`${keyClass} tt-key-sm`} data-code="Digit1">1</div>
          <div class={`${keyClass} tt-key-sm`} data-code="Digit2">2</div>
          <div class={`${keyClass} tt-key-sm`} data-code="Digit3">3</div>
          <div class={`${keyClass} tt-key-sm`} data-code="Digit4">4</div>
          <div class={`${keyClass} tt-key-sm`} data-code="Digit5">5</div>
          <div class={`${keyClass} tt-key-sm`} data-code="Digit6">6</div>
          <div class={`${keyClass} tt-key-sm`} data-code="Digit7">7</div>
          <div class={`${keyClass} tt-key-sm`} data-code="Digit8">8</div>
          <div class={`${keyClass} tt-key-sm`} data-code="Digit9">9</div>
          <div class={`${keyClass} tt-key-sm`} data-code="Digit0">0</div>
          <div class={`${keyClass} tt-key-sm`} data-code="Minus">-</div>
          <div class={`${keyClass} tt-key-sm`} data-code="Equal">=</div>
          <div class={`${keyClass} tt-key-md`} data-code="Backspace">BACK</div>
          <div class="tt-spacer-4"></div>
          <div class={`${keyClass} tt-key-sm`} data-code="Insert">INS</div>
          <div class={`${keyClass} tt-key-sm`} data-code="Home">HOM</div>
          <div class={`${keyClass} tt-key-sm`} data-code="PageUp">PGU</div>
        </div>

        <div class="tt-row">
          <div class={`${keyClass} tt-key-md`} data-code="Tab">TAB</div>
          <div class={`${keyClass} tt-key-sm`} data-code="KeyQ">Q</div>
          <div class={`${keyClass} tt-key-sm`} data-code="KeyW">W</div>
          <div class={`${keyClass} tt-key-sm`} data-code="KeyE">E</div>
          <div class={`${keyClass} tt-key-sm`} data-code="KeyR">R</div>
          <div class={`${keyClass} tt-key-sm`} data-code="KeyT">T</div>
          <div class={`${keyClass} tt-key-sm`} data-code="KeyY">Y</div>
          <div class={`${keyClass} tt-key-sm`} data-code="KeyU">U</div>
          <div class={`${keyClass} tt-key-sm`} data-code="KeyI">I</div>
          <div class={`${keyClass} tt-key-sm`} data-code="KeyO">O</div>
          <div class={`${keyClass} tt-key-sm`} data-code="KeyP">P</div>
          <div class={`${keyClass} tt-key-sm`} data-code="BracketLeft">[</div>
          <div class={`${keyClass} tt-key-sm`} data-code="BracketRight">]</div>
          <div class={`${keyClass} tt-key-md`} data-code="Backslash">\</div>
          <div class="tt-spacer-4"></div>
          <div class={`${keyClass} tt-key-sm`} data-code="Delete">DEL</div>
          <div class={`${keyClass} tt-key-sm`} data-code="End">END</div>
          <div class={`${keyClass} tt-key-sm`} data-code="PageDown">PGD</div>
        </div>

        <div class="tt-row">
          <div class={`${keyClass} tt-key-lg`} data-code="CapsLock">CAPS</div>
          <div class={`${keyClass} tt-key-sm`} data-code="KeyA">A</div>
          <div class={`${keyClass} tt-key-sm`} data-code="KeyS">S</div>
          <div class={`${keyClass} tt-key-sm`} data-code="KeyD">D</div>
          <div class={`${keyClass} tt-key-sm`} data-code="KeyF">F</div>
          <div class={`${keyClass} tt-key-sm`} data-code="KeyG">G</div>
          <div class={`${keyClass} tt-key-sm`} data-code="KeyH">H</div>
          <div class={`${keyClass} tt-key-sm`} data-code="KeyJ">J</div>
          <div class={`${keyClass} tt-key-sm`} data-code="KeyK">K</div>
          <div class={`${keyClass} tt-key-sm`} data-code="KeyL">L</div>
          <div class={`${keyClass} tt-key-sm`} data-code="Semicolon">;</div>
          <div class={`${keyClass} tt-key-sm`} data-code="Quote">'</div>
          <div class={`${keyClass} tt-key-lg`} data-code="Enter">ENTER</div>
          <div class="tt-spacer-108"></div>
        </div>

        <div class="tt-row">
          <div class={`${keyClass} tt-key-lg`} data-code="ShiftLeft">SHIFT</div>
          <div class={`${keyClass} tt-key-sm`} data-code="KeyZ">Z</div>
          <div class={`${keyClass} tt-key-sm`} data-code="KeyX">X</div>
          <div class={`${keyClass} tt-key-sm`} data-code="KeyC">C</div>
          <div class={`${keyClass} tt-key-sm`} data-code="KeyV">V</div>
          <div class={`${keyClass} tt-key-sm`} data-code="KeyB">B</div>
          <div class={`${keyClass} tt-key-sm`} data-code="KeyN">N</div>
          <div class={`${keyClass} tt-key-sm`} data-code="KeyM">M</div>
          <div class={`${keyClass} tt-key-sm`} data-code="Comma">,</div>
          <div class={`${keyClass} tt-key-sm`} data-code="Period">.</div>
          <div class={`${keyClass} tt-key-sm`} data-code="Slash">/</div>
          <div class={`${keyClass} tt-key-xl`} data-code="ShiftRight">SHIFT</div>
          <div class="tt-spacer-4"></div>
          <div class="tt-spacer-12"></div>
          <div class={`${keyClass} tt-key-sm`} data-code="ArrowUp">↑</div>
          <div class="tt-spacer-12"></div>
        </div>

        <div class="tt-row">
          <div class={`${keyClass} tt-key-md`} data-code="ControlLeft">CTRL</div>
          <div class={`${keyClass} tt-key-sm`} data-code="MetaLeft">WIN</div>
          <div class={`${keyClass} tt-key-md`} data-code="AltLeft">ALT</div>
          <div class={`${keyClass} tt-key-xxl`} data-code="Space">SPACE</div>
          <div class={`${keyClass} tt-key-md`} data-code="AltRight">ALT</div>
          <div class={`${keyClass} tt-key-sm`} data-code="MetaRight">WIN</div>
          <div class={`${keyClass} tt-key-sm`} data-code="ContextMenu">CTX</div>
          <div class={`${keyClass} tt-key-md`} data-code="ControlRight">CTRL</div>
          <div class="tt-spacer-4"></div>
          <div class={`${keyClass} tt-key-sm`} data-code="ArrowLeft">←</div>
          <div class={`${keyClass} tt-key-sm`} data-code="ArrowDown">↓</div>
          <div class={`${keyClass} tt-key-sm`} data-code="ArrowRight">→</div>
        </div>
      </div>
    </div>

    <div class="tt-event-log-container">
        <div class="tt-event-log-header">
          <Icon name="mdi:history" class="tt-event-log-icon" />
          <h3 class="tt-event-log-label">{t.eventLogLabel}</h3>
        </div>
        <div id="event-log" class="tt-event-log"></div>
      </div>
    </div>
  </div>

  
  <script>
    const activeClass = 'tt-key-active';
    const testedClass = 'tt-key-tested';

    const activeClasses = [activeClass];
    const testedClasses = [testedClass];

    const keys = document.querySelectorAll('[data-code]');
    const maxKroDisplay = document.getElementById('max-kro');
    const eventLog = document.getElementById('event-log');
    const resetBtn = document.getElementById('reset-btn');

    const activeKeys = new Set<string>();
    let maxSimultaneous = 0;

    const keyMap = new Map<string, Element>();
    keys.forEach((k) => {
      const code = k.getAttribute('data-code');
      if (code) keyMap.set(code, k);
    });

    function log(msg: string) {
      if (!eventLog) return;
      const div = document.createElement('div');
      div.textContent = `${msg}`;
      eventLog.appendChild(div);
      if (eventLog.children.length > 50) eventLog.firstElementChild?.remove();
      eventLog.scrollLeft = eventLog.scrollWidth;
    }

    function handleDown(e: KeyboardEvent) {
      e.preventDefault();
      const code = e.code;

      if (!activeKeys.has(code)) {
        activeKeys.add(code);

        const el = keyMap.get(code) as HTMLElement | undefined;
        if (el) {
          el.classList.add(...activeClasses);
          el.classList.add('is-tested');

          if (!el.dataset.tested) {
            el.classList.add(...testedClasses);
            el.dataset.tested = 'true';
          }

          const keyText = el.textContent || code;
          log(`${keyText}`);
        }

        if (activeKeys.size > maxSimultaneous) {
          maxSimultaneous = activeKeys.size;
          if (maxKroDisplay) maxKroDisplay.textContent = maxSimultaneous.toString();
        }
      }
    }

    function handleUp(e: KeyboardEvent) {
      e.preventDefault();
      const code = e.code;
      activeKeys.delete(code);

      const el = keyMap.get(code) as HTMLElement | undefined;
      if (el) {
        el.classList.add('tt-key-releasing');
        el.classList.remove('tt-key-active');
        el.classList.remove('tt-key-tested');
        setTimeout(() => {
          el.classList.remove('tt-key-releasing');
        }, 300);
      }
    }

    function reset() {
      activeKeys.clear();
      maxSimultaneous = 0;
      if (maxKroDisplay) maxKroDisplay.textContent = '0';
      if (eventLog) eventLog.innerHTML = '';

      keys.forEach((k) => {
        k.classList.remove(...activeClasses);
        k.classList.remove(...testedClasses);
        (k as HTMLElement).removeAttribute('data-tested');
        k.classList.remove('is-tested');
      });
      log('Test reiniciado.');
    }

    window.addEventListener('keydown', handleDown);
    window.addEventListener('keyup', handleUp);
    resetBtn?.addEventListener('click', reset);

    window.focus();
  </script>
</div>
