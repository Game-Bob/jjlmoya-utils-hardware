---
import type { KnownLocale } from '../../types';
import type { EstimadorSaludBateriaUI } from './ui';
import { Icon } from 'astro-icon/components';

interface Props {
  locale?: KnownLocale;
  ui?: Record<string, unknown>;
}

const { ui } = Astro.props;
const t = (ui ?? {}) as EstimadorSaludBateriaUI;

const S = JSON.stringify({
  se: t.statusExcelente, sb: t.statusBueno, sr: t.statusRegular, sc: t.statusCritico,
  yp: t.yearsPrefix, ys: t.yearsSuffix,
  tn: t.indicatorTempNormal, tc: t.indicatorTempCritical,
  vh: t.indicatorVoltageHigh, vl: t.indicatorVoltageLow,
  pr: t.indicatorPlatingRisk, po: t.indicatorPlatingOk,
  rt: t.recTemp, rvh: t.recVoltageHigh, rvl: t.recVoltageLow,
  rs: t.recSohLow, rd: t.recDefault,
});
---

<div id="bh-root" class="bh-wrapper" data-s={S}>

  
  <div class="bh-grid">

    <div class="bh-left">
      <div class="bh-params-panel">
        <h3 class="bh-params-title">
          <Icon name="mdi:battery-check" class="bh-params-icon" />
          {t.paramsTitle}
        </h3>

        <div class="bh-sliders">
          <div class="bh-slider-group">
            <div class="bh-slider-header">
              <label class="bh-slider-label">{t.voltageLabel}</label>
              <span id="bh-v-val" class="bh-slider-val">3.70V</span>
            </div>
            <input type="range" id="bh-v" class="bh-slider" min="3.0" max="4.2" step="0.01" value="3.70" />
            <p class="bh-slider-hint">{t.voltageHint}</p>
          </div>

          <div class="bh-slider-group">
            <div class="bh-slider-header">
              <label class="bh-slider-label">{t.cyclesLabel}</label>
              <span id="bh-c-val" class="bh-slider-val">50</span>
            </div>
            <input type="range" id="bh-c" class="bh-slider" min="0" max="1000" step="1" value="50" />
          </div>

          <div class="bh-slider-group">
            <div class="bh-slider-header">
              <label class="bh-slider-label">{t.tempLabel}</label>
              <span id="bh-t-val" class="bh-slider-val">25°C</span>
            </div>
            <input type="range" id="bh-t" class="bh-slider" min="0" max="60" step="1" value="25" />
          </div>
        </div>
      </div>

      <div id="bh-status-card" class="bh-status-card" data-status="excelente">
        <span id="bh-status-text" class="bh-status-text">{t.statusExcelente}</span>
        <div id="bh-recs" class="bh-recs"></div>
      </div>
    </div>

    <div class="bh-right">
      <div class="bh-ring-wrap">
        <div class="bh-ring-glow"></div>
        <div class="bh-ring-container">
          <svg class="bh-ring-svg">
            <circle class="bh-ring-track" cx="50%" cy="50%" r="45%" stroke-width="12" fill="transparent"></circle>
            <circle id="bh-ring" class="bh-ring-progress" cx="50%" cy="50%" r="45%" stroke-width="12" fill="transparent" stroke-dasharray="100 100" stroke-linecap="round"></circle>
          </svg>
          <div class="bh-ring-overlay">
            <span class="bh-ring-label">{t.labelUsefulLife}</span>
            <div class="bh-ring-value">
              <span id="bh-soh">100</span>
              <span class="bh-ring-pct">%</span>
            </div>
            <div id="bh-years" class="bh-ring-years"></div>
          </div>
        </div>
      </div>

      <div class="bh-indicators">
        <div class="bh-indicator">
          <span class="bh-indicator-title">{t.metricThermalStress}</span>
          <div class="bh-indicator-row">
            <div id="bh-dot-t" class="bh-dot"></div>
            <span id="bh-lbl-t" class="bh-indicator-label">{t.indicatorTempNormal}</span>
          </div>
        </div>
        <div class="bh-indicator">
          <span class="bh-indicator-title">{t.metricVoltageStress}</span>
          <div class="bh-indicator-row">
            <div id="bh-dot-v" class="bh-dot"></div>
            <span id="bh-lbl-v" class="bh-indicator-label">{t.indicatorVoltageLow}</span>
          </div>
        </div>
        <div class="bh-indicator">
          <span class="bh-indicator-title">{t.metricLithiumPlating}</span>
          <div class="bh-indicator-row">
            <div id="bh-dot-p" class="bh-dot"></div>
            <span id="bh-lbl-p" class="bh-indicator-label">{t.indicatorPlatingOk}</span>
          </div>
        </div>
      </div>
    </div>

  </div>

  
  <script>
    const root = document.getElementById('bh-root');
    const S: Record<string, string> = JSON.parse(root?.dataset?.s ?? '{}');
    const C = { OK: '#10b981', WARN: '#f59e0b', DANGER: '#f43f5e', BLUE: '#3b82f6' };
    const RT = S.rt ?? '', RVH = S.rvh ?? '', RVL = S.rvl ?? '', RS = S.rs ?? '', RD = S.rd ?? '';
    const TN = S.tn ?? '', TC = S.tc ?? '', VH = S.vh ?? '', VL = S.vl ?? '';
    const PR = S.pr ?? '', PO = S.po ?? '', YP = S.yp ?? 'Est.', YS = S.ys ?? 'años';
    const STATUS_CSS: Record<string, string> = { se: 'excelente', sb: 'bueno', sr: 'regular', sc: 'critico' };
    const STATUS_TXT: Record<string, string> = { se: S.se ?? '', sb: S.sb ?? '', sr: S.sr ?? '', sc: S.sc ?? '' };
    const slV = document.getElementById('bh-v') as HTMLInputElement | null;
    const slC = document.getElementById('bh-c') as HTMLInputElement | null;
    const slT = document.getElementById('bh-t') as HTMLInputElement | null;
    const valV = document.getElementById('bh-v-val');
    const valC = document.getElementById('bh-c-val');
    const valT = document.getElementById('bh-t-val');
    const sohEl = document.getElementById('bh-soh');
    const yearsEl = document.getElementById('bh-years');
    const ring = document.getElementById('bh-ring') as unknown as SVGCircleElement | null;
    const statusCard = document.getElementById('bh-status-card') as HTMLElement | null;
    const statusText = document.getElementById('bh-status-text');
    const recsEl = document.getElementById('bh-recs');
    const dotT = document.getElementById('bh-dot-t') as HTMLElement | null;
    const lblT = document.getElementById('bh-lbl-t');
    const dotV = document.getElementById('bh-dot-v') as HTMLElement | null;
    const lblV = document.getElementById('bh-lbl-v');
    const dotP = document.getElementById('bh-dot-p') as HTMLElement | null;
    const lblP = document.getElementById('bh-lbl-p');

    function tempFactor(t: number): number {
      if (t > 45) return 2 + (t - 45) * 0.1;
      if (t > 30) return 1 + (t - 30) * 0.05;
      if (t < 10) return 1.2;
      return 1;
    }

    function voltFactor(v: number): number {
      if (v > 4.15) return 1.8;
      if (v > 4.05) return 1.3;
      if (v < 3.2) return 1.2;
      return 1;
    }

    function healthKey(soh: number): string {
      if (soh < 65) return 'sc';
      if (soh < 80) return 'sr';
      if (soh < 90) return 'sb';
      return 'se';
    }

    function getRecs(v: number, t: number, soh: number): string[] {
      const recs: string[] = [];
      if (t > 35) recs.push(RT);
      if (v > 4.1) recs.push(RVH);
      if (v < 3.3) recs.push(RVL);
      if (soh < 80) recs.push(RS);
      if (recs.length === 0) recs.push(RD);
      return recs;
    }

    function calculate(v: number, c: number, t: number) {
      const tp = tempFactor(t);
      const vs = voltFactor(v);
      const soh = Math.max(0, 100 - (c / 500) * 20 * tp * vs);
      const life = Math.max(0, 5 * (soh / 100) * (1 / (tp * vs)));
      return { soh: Math.round(soh * 10) / 10, life: Math.round(life * 10) / 10, key: healthKey(soh) };
    }

    function applyDot(dot: HTMLElement | null, lbl: Element | null, color: string, text: string) {
      if (!dot || !lbl) return;
      dot.style.background = color;
      lbl.textContent = text;
    }

    function updateRing(soh: number) {
      if (!ring) return;
      const r = ring.r.baseVal.value;
      const circ = 2 * Math.PI * r;
      ring.style.strokeDasharray = `${circ} ${circ}`;
      ring.style.strokeDashoffset = (circ - (soh / 100) * circ).toString();
      let ringColor = C.DANGER;
      if (soh > 70) ringColor = C.WARN;
      if (soh > 85) ringColor = C.OK;
      ring.style.stroke = ringColor;
    }

    function updateSliders(v: number, c: number, t: number) {
      if (valV) valV.textContent = `${v.toFixed(2)}V`;
      if (valC) valC.textContent = c.toString();
      if (valT) valT.textContent = `${t}°C`;
    }

    function updateIndicators(v: number, t: number) {
      const tWarn = t > 40, vWarn = v > 4.1, pWarn = t < 10;
      applyDot(dotT, lblT, tWarn ? C.DANGER : C.OK, tWarn ? TC : TN);
      applyDot(dotV, lblV, vWarn ? C.WARN : C.OK, vWarn ? VH : VL);
      applyDot(dotP, lblP, pWarn ? C.BLUE : C.OK, pWarn ? PR : PO);
    }

    function applyStatus(key: string, v: number, t: number, soh: number) {
      if (statusCard) statusCard.dataset.status = STATUS_CSS[key] ?? 'excelente';
      if (statusText) statusText.textContent = STATUS_TXT[key] ?? '';
      if (recsEl) recsEl.innerHTML = getRecs(v, t, soh).map((r) => `<div class="bh-rec"><span class="bh-rec-dot"></span><p>${r}</p></div>`).join('');
    }

    function update() {
      if (!slV || !slC || !slT) return;
      const v = parseFloat(slV.value);
      const c = parseInt(slC.value, 10);
      const t = parseInt(slT.value, 10);
      updateSliders(v, c, t);
      const { soh, life, key } = calculate(v, c, t);
      if (sohEl) sohEl.textContent = Math.round(soh).toString();
      if (yearsEl) yearsEl.textContent = `${YP} ${life.toFixed(1)} ${YS}`;
      updateRing(soh);
      updateIndicators(v, t);
      applyStatus(key, v, t, soh);
    }

    [slV, slC, slT].forEach((el) => el?.addEventListener('input', update));
    update();
  </script>
</div>
